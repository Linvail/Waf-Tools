#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import os
import sys
import subprocess

def main():
    # Get the directory of this wrapper script
    cwd = os.path.dirname(os.path.abspath(__file__))
    # Path to the real waf script in the submodule
    waf_path = os.path.join(cwd, 'submodules', 'external', 'waf', 'waf')

    # Run the real waf script with Python
    cmd = [sys.executable, waf_path] + sys.argv[1:]

    # Run and forward exit code
    try:
        result = subprocess.run(cmd)
        sys.exit(result.returncode)
    except KeyboardInterrupt:
        sys.exit(1)

if __name__ == '__main__':
    main()
