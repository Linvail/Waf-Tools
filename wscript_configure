from waflib import Configure, Context, Errors, Options, Utils, Logs
from waflib.Configure import conf
from waflib.extras import msvs
import glob, os

local_tools = [
    "variant-builder",
    "toolchains",
    "debug-info",
]

ctx.load(local_tools, tooldir='tools')

ctx.env.PREFIX = "./usr"

# Track all tools files for Waf's autoconfig Node hashing
if os.path.exists('tools'):
    for f in glob.glob('tools/**/*.py', recursive=True):
        abspath = os.path.abspath(f)
        ctx.files.append(abspath)
        ctx.hash = Utils.h_list((ctx.hash, Utils.readf(abspath, 'rb')))
