from waflib import Configure, Context, Errors, Options, Utils, Logs
from waflib.Configure import conf
from waflib.extras import msvs
import glob, os

local_tools = [
    "variant-builder",
    "toolchains",
    "debug-info",
]

ctx.load(local_tools, tooldir='tools')
ctx.load('clang_compilation_database', tooldir='submodules/external/waf/waflib/extras')

# Monkey-patch clangdb to copy compile_commands.json to the workspace root
import sys, shutil
clang_db_module = sys.modules.get('clang_compilation_database')
if clang_db_module:
    old_write = clang_db_module.ClangDbContext.write_compilation_database
    def new_write(self):
        old_write(self)
        database_file = self.bldnode.make_node('compile_commands.json')
        if os.path.exists(database_file.abspath()):
            dest_path = os.path.join(self.srcnode.abspath(), 'compile_commands.json')
            try:
                shutil.copy2(database_file.abspath(), dest_path)
                Logs.info('Copied compile_commands.json to workspace root: %s' % dest_path)
            except Exception as e:
                Logs.warn('Failed to copy compile_commands.json to root: %s' % e)
    clang_db_module.ClangDbContext.write_compilation_database = new_write


ctx.env.PREFIX = "./usr"

# Track all tools files for Waf's autoconfig Node hashing
if os.path.exists('tools'):
    for f in glob.glob('tools/**/*.py', recursive=True):
        abspath = os.path.abspath(f)
        ctx.files.append(abspath)
        ctx.hash = Utils.h_list((ctx.hash, Utils.readf(abspath, 'rb')))
